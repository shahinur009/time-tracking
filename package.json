{
  "name": "time-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone time tracker with ClickUp OAuth integration",
  "author": "Dorik",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @tt/api dev",
    "dev:web": "pnpm --filter @tt/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "seed:admin": "pnpm --filter @tt/api seed:admin"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
